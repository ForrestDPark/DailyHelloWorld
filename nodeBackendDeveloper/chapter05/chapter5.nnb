            "language": "typescript",
            "source": [
                "function waitOneSecond(msg) { // 1초 대기 후 메세지 출력 \n    return new Promise((resolve, _) => {\n        setTimeout(() => {\n            resolve(`${msg}`);\n        }\n        ,1000);\n    });\n}\nasync function countOneToTen() {\n    console.log(\"start\")\n    for (let x of [...Array(10).keys()]) {\n        let result = await waitOneSecond(`${x + 1}초 대기중 ...`);\n        \n        console.log(result);\n        console.log(x)\n    }\n\n    console.log([...Array(10).keys()]);\n}\n\ncountOneToTen();"
            ],

            "language": "typescript",
            "source": [
                "const { r, y, g, b, bold, underline, reverse, bgRed, bgGreen } = require('./txtFunc');\n// Mongoos, express CRUD test\nconst {MongoClient, ServerApiVersion} = require('mongodb')\nconst express = require(\"express\")\nconst bodyParser = require(\"body-parser\")\nconst mongoose = require(\"mongoose\")\nconst Person = require(\"./person-model\")\n\n\n// 1. 경고 무시 설정\nmongoose.set(\"strictQuery\", false); \n// 몽구스에서 쿼리에 필터를 빈객체 {} 로 넣으면 모든값을 불러오게 되어 에러 \n\nconst app = express();\n\n//2. HTTP 에서 body 를 파싱하기 위한설정\napp.use(bodyParser.json()) \n// app.use(bodyParser.text())\n// app.use(bodyParser.text({ type: 'text/plain' }));\n// app.use(bodyParser.urlencoded({extended :true}))\napp.listen(80, async() => {\n    console.log(\"Server started\")\n\n    // const MongoClient = require('mongodb').MongoClient;\n    \n    const url = \"mongodb+srv://pulpilisory:qwe123@cluster0.kbog4.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0\";\n    \n    const client = new MongoClient(url, {\n      serverApi: {\n        version: ServerApiVersion.v1,\n        strict: true,\n        deprecationErrors: true,\n      }\n    });\n\n    // 3. mongoDB connection \n    // error : useNewUrlParser 는 4.0 부터는 사용하지 않음. \n    // error : useUnifiedTopology 는 4.0 부터는 사용하지 않음. \n    mongoose\n      .connect(url)\n      .then(console.log(\"Connected to MongoDB with Mongoose\"))\n      .catch((error) => console.error(\"Mongoose connection error:\", error));\n})\n\n\n// 4. 모든 person 데이터 출력 \napp.get(\"/person\", async (req,res) => {\n  const person = await Person.find({});\n\n  // 특정 필드 제외시 .find({}, {name:1, email:0})\n  // sorting : .find({},{sort: {name:1}})\n  // limit(문서수 지정) : Person.find({},{limit:10})\n  // skip(앞에서 제외할 문서수 지정) : .find({},{skip:5})\n  res.send(person);\n})\n\n// 5. 특정 이메일로 person 찾기 \napp.get(\"/person/:email\", async (req, res)=> {\n  const person = await Person.findOne({ email: req.params.email})\n  res.send(person)\n})\n\n// 6. person 데이터 추가하가ㅣ \napp.post(\"/personal\", async (req, res) => {\n  console.log(\"request logs \")\n  console.log(\"request headers:\",req.headers)\n  console.log(\"request body ===> \",req.body)\n  try {\n    const person = new Person(req.body)\n    // await person.save()\n    const result = await Person.create(req.body) //로 추가 해도됨\n    res.send(result)\n  } catch (error) {\n    console.error(\"Error creating person\",error)\n    res.status(500).send({error: \"내부 서버 에러 \"})\n  }\n\n})\n\n// 7. person data 수정하기 \napp.put(\"/person/:email\", async (req,res)=> {\n  const person = await Person.findOneAndUpdate(//문서 하나만 찾아서 수정하는 경우 updateOne() 과 같음.\n    {email: req.params.email},\n    {$set: req.body},\n    {new: true}\n  )\n  console.log(person)\n  res.send(person)\n})\n//  8. person 데이터 삭제하기 \napp.delete(\"/person/:email\", async (req,res) => {\n  await Person.deleteMany({ email : req.params.email});\n  res.send({ success: true})\n})\n"

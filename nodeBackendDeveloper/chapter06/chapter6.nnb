                "const {MongoClient, ServerApiVersion} = require('mongodb')\n\n// const MongoClient = require('mongodb').MongoClient;\n\nconst url = \"mongodb+srv://pulpilisory:qwe123@cluster0.kbog4.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0\";\n\nconst client = new MongoClient(url, {\n  serverApi: {\n    version: ServerApiVersion.v1,\n    strict: true,\n    deprecationErrors: true,\n  }\n});\n\n// const client = new MongoClient(url, { userNewUrlParser: true});\n\nasync function main(){\n  try {\n    // connection 생성및 연결 시도 \n    await client.connect();\n    console.log(\"Mongo db 접속 성공\");\n\n    const collection = client.db('test').collection('person')// test db 에 person collection 을 사용, 없으면 생성후 사용\n    // Insert\n    await collection.insertOne({name: 'Forrest', age:30});\n    console.log(\"문서 추가 완료\")\n\n    // Read\n    const documents = await collection.find({name: \"Forrest\"}).toArray();\n    // console.log(documents)\n\n    // Update \n    await collection.updateOne({ name : \"Forrest\"}, {$set: {age: 31}});\n    console.log('문서 업데이트 ')\n\n    // Update 된것 확인 \n    const updatedDocuments = await collection.find({name : \"Forrest\"}).toArray()\n    console.log(\"갱신된 문서 : \", updatedDocuments)\n    \n    // await collection.deleteOne({name : \"Forrest\"});\n    // console.log('문서 삭제 ');\n    await client.close()\n  } catch (err){\n    console.error(err)\n  }\n  finally {\n\n  }\n}\n\nmain()\n"

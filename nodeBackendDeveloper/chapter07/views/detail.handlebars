<!--views/detail.handlebars-->
<h1>{{title}}</h1>

{{#with post}} 
{{!-- post 객체 내에 title 필드가 없는경우에는 아무것도 표시하지 않는다! --}}
<h2 class="text-xl"> {{title}}</h2>
<div>
    작성자 : <b>{{writer}}</b>
</div>

<div>
    조회수 : {{hits}} | 작성일시 :{{dateString createdDt}}
    <button onclick="modifyPost()">수정</button>
    <button onclick="deletePost()">삭제</button>
</div>

<div>
    <pre>{{content}}</pre>
</div>

<section>
    <div>
        <h3> {{lengthOfList comments}} 개의 댓글이 있습니다. </h3>
    </div>
    <!-- (7) 댓글 작성폼 -->
    <form method="post" action="/write-comment">
        {{!-- 게시글 아이디를 히든으로 저장해둠 --}}
        <input type="hidden" name="id" value="{{_id}}">  
        <div>
            <input type="text" name="name" placeholder="input name" />
            <input type="password" name="password" placeholder="input password" />
        </div>
        <div>
            <textarea cols="40" rows="3" name="comment" placeholder="Please input your comment."></textarea>
            <!--댓글 전송 버튼-->
            <br/> <br/> <button> Write comment</button>
        </div>
    </form>
</section>
{{!-- 댓글 표시 영역 --}}
<section>
    <!-- post db에는 comment 라는 필드가 없으나 그냥 일단 생성하고본다? -->
    <!-- comments 에는 comment 가 있다. -->
    {{#each comments}}
    <div>
        <div>
            commenter : <b>{{name}}</b>
        </div>
        <div>
            comment date: {{dateString createdDt}}
            <button onclick="deleteComment('{{idx}}')">Delete</button>
        </div>
    </div>
    <div>
        <pre>{{comment}}</pre>
    </div>
    {{/each}}
</section>
{{/with}}

<footer>
    <div>
        <a href="/">목록으로</a>
    </div>
</footer>

<script>
/*1. Post 수정 함수 */
// 1.0 수정에 필요한 정보를 json type 의 post 방식으로 보내겠다는 옵션 객체 
const postOption ={
    method : 'POST',
    headers : {
        'Content-Type' : 'application/json'
    }
}

async function modifyPost() {
    const password = prompt("please input your password")
    // 1.1 프롬프트에서 취소를 누른경우 처리
    if (!password) {
        console.log(" 비밀번호 입력되지 않음 취소 버튼 눌림")
        return
    }
    // 1.2 check-password API 실행 
    // password 변수에 사용자가 입력한 비밀번호가 저장되어있음. 
    // check path 워드라는 라우터안에서 실행되는 응답을 위해 요청시 필요한 내용(postid , password)를 바디에 작성
    // fetch(url,option) 형태로 작성됨. 
    const result = await fetch("/check-password", {
        ...postOption,
        // 서버로 보낼 데이터를 담는곳. 게시글의 id와 사용자가 입력한 비밀호를 json 으로 보냄. 
        body : JSON.stringify({id: "{{post._id}}", password})
        // stringify 역할  : {id:"123", pw:"123"} ==> {"id":"123","pw":"123"}
    })
    // 1.3 result 변수에는 fetch 함수가 성공적으로 실행된 후 서버에서 받아온 응답이 저장됨 
    const data = await result.json()
    

    // 1.4 패스워드가 맞는 경우(data.isExit =true) 수정 페이지로 이동
    if (data.isExit) {
        document.location = "/modify/{{post._id}}"
    } else {
        alert("Wrong Password.")
    }

}
/* 2. 글 삭제 함수 */
const deleteOption = {
    method: 'DELETE',
    headers: {
        'Content-Type' : 'application/json'
    }
}
async function deletePost() { 
    // 2.1  프롬프트 값 입력 받음. 
    const password = prompt("Please input password.")

    if (!password) {
        return
    }
    // 2.2 fetch api 를 사용해 delete api 호출 
    const resutl = await fetch("/delete", {
        ...deleteOption,
        body : JSON.stringify({id: "{{post._id}}", password})
    })
    // 2.3 delete api 의 결과에 따라 다른 메시지 출력 
    const data = await result.json();
    if (!data.isSuccess) {
        alert(" Fail to delete. Please check your password.")
        return
    }
    document.location = "/"
}

/* 3. 댓글 삭제 함수 */
async function deleteComment(idx) {
    const password = prompt("input password.")
    // 3.1 프롬프트에서 취소 
    if (!password){
        return 
    } 

    // 3.2 delete-comment api 실행 
    const result = await fetch("/delete-comment", {
        ...deleteOption,
        body : JSON.stringify({ id: "{{post._id}}", idx, password})
    })
    // 3.3 댓글 삭제 실패 시 메시지 띄우고 함수 실행 종료 
    const data = await result.json()
    if (!data.isSuccess) {
        alert(" Fail to delete .check your password")
        return
    }
    // 3.4 성공시 메시지를 띄우고 화면 refresh 
    alert("delete success!")
    document.location.reload()
}


</script>



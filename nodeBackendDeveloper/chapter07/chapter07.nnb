            "language": "html",
            "source": [
                "<!--views/layouts/main.handlebars-->\n<html>\n    <head>\n        <meta charset=\"utf-8\"/>\n        <title> GRK Partners Research Platform</title>\n\n    </head>\n    <body>\n        {{{body}}} \n    </body>\n</html>"
            ],
            "outputs": []
        },
        {
            "language": "html",
            "source": [
                "<h2>{{title}}</h2>\n<p>{{message}}</p>"
            ],
            "outputs": []
        },
        {
            "language": "html",
            "source": [
                "<!--home.handlebars-->\n<!--title 영역 -->\n<h1>{{title}}</h1>\n\n<!-- 검색어 영역 -->\n<!-- (1) value 에 검색어 데이터를 넣음. -->\n<input type=\"text\" name=\"search\" id=\"search\" value=\"{{search}}\"\n size=\"50\" placeholder=\"Input search word\"/>\n<!-- (2) 버튼 클릭시 search 변수에 검색어 데이터를 담아서 서버로 보냄. -->\n<button onclick =\"location.href=`/?search=${document.getElementById('search').value}`\">검색</button>\n<br />\n<a href=\"/write\"> 글쓰기 </a>\n\n<br>\n<!-- <p> 이페이지에서 사용하는 변수들 </p>\n<p> id : {{_id}}</p>\n<p> root :{{@root}}</p>\n<p> posts :{{posts}}</p> -->\n\n<div>\n    <table>\n        <thead>\n            <tr>\n                <th width = \"50%\">제목</th>\n                <th>작성자</th>\n                <th>조회수</th>\n                <th>등록일</th>\n            </tr>\n        </thead>\n        <!-- (1) 게시글 데이터 표시 -->\n        <tbody>\n            {{#each posts}}\n            <tr>\n                <!-- (2) 상세 페이지 링크 -->\n                <td><a href=\"/detail/{{_id}}\">{{title}}</a></td>\n\n                <td align=\"center\">{{writer}}</td>\n                <td align=\"center\">{{hits}}</td>\n\n                <!-- (3) dateString 헬퍼 함수 사용 -->\n                <td align=\"center\">{{dateString createdDt}}</td>\n            </tr>\n            {{/each}}\n        </tbody>\n    </table>\n</div>\n\n<!--페이징 영역-->\n<div>\n    <!--(4) with 내장 헬퍼 함수 paginator 객체 가 컨택스트가 됨.-->\n    {{#with paginator}}\n    <!-- (5) @root :서버의 최상위 컨텍스트 참조, '<<' 링크를 통해 page 1로 이동  (괄호는 &lt 사용)-->\n    <a href=\"/?page=1&search={{@root.search}}\">&lt;&lt;</a>\n    {{#if hasPrev}}\n    <a href=\"/?page={{prevPage}}&search={{@root.search}}\"\">&lt;</a>\"\n    <!-- (6) 1페이지 인 경우 이전 페이지 가 없으므로 링크가 없음 -->\n    {{else}} \n    <a>&lt</a>\n    {{/if}}\n    <!-- 현재 페이지 번호 리스트 나타내기 -->\n    {{#each pageList}}\n    {{#if (eq . @root.paginator.page)}}\n    <a>{{.}}</a>\n    {{else}}\n    <a href=\"/?page={{.}}&search={{@root.search}}\">{{.}}</a>\n    {{/if}}\n    {{/each}}\n\n    <!-- '>>' 부분 구현  -->\n    {{#if hasNext}}\n    <a href=\"/?page={{nextPage}}&search={{@root.search}}\">&gt;</a>\n\n    {{else}}\n    <a>&gt;</a>\n    {{/if}}\n    <a href=\"/?page={{lastPage}}&search={{@root.search}}\">&gt;&gt;</a>\n    \n    {{/with}}\n</div>\n\n\n\n<!--페이징 영역 초기 모델 -->\n<!-- <div>\n    <a>&lt;&lt;</a>\n    <a>&lt;</a>\n    <a>1</a>\n    <a>2</a>\n    <a>3</a>\n    <a>4</a>\n    <a>&gt;</a>\n    <a>&gt;&gt;</a>\n</div> -->"
            ],
            "outputs": []
        }
    ]
}